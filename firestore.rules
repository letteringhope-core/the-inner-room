rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /prayers/{prayerId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000;

      // Only the reaction fields may change on an existing post.
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['prayedBy', 'praying'])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.text == resource.data.text;

      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    match /notes/{noteId} {
      // Multiple notes per day now, auto-generated ids, always fetched
      // via a `where('uid','==',...)` query so resource always exists
      // here (no not-yet-written case like dayLogs/notes-by-date below).
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.date is string
        && request.resource.data.reflection is string
        && request.resource.data.reflection.size() > 0
        && request.resource.data.reflection.size() <= 4000;

      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    match /dayLogs/{logId} {
      // One doc per day, id convention `${uid}_${date}`. Same get/list
      // split as before: get() may target a not-yet-written day.
      allow get: if request.auth != null
        && logId.matches(request.auth.uid + '_.*');

      allow list: if request.auth != null
        && resource.data.uid == request.auth.uid;

      allow write: if request.auth != null
        && logId.matches(request.auth.uid + '_.*')
        && request.resource.data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
