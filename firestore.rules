rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /prayers/{prayerId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000;

      // Only the reaction fields may change on an existing post.
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['prayedBy', 'praying'])
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.text == resource.data.text;

      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    match /notes/{noteId} {
      // Single-doc get: doc id convention is `${uid}_${date}` - match on
      // that instead of resource.data, since resource is null for a
      // not-yet-written note and the get must still succeed.
      allow get: if request.auth != null
        && noteId.matches(request.auth.uid + '_.*');

      // Collection queries (e.g. this month's notes): resource always
      // exists here, and Firestore can verify a `where('uid','==',uid)`
      // query is safe against this condition.
      allow list: if request.auth != null
        && resource.data.uid == request.auth.uid;

      allow write: if request.auth != null
        && noteId.matches(request.auth.uid + '_.*')
        && request.resource.data.uid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
